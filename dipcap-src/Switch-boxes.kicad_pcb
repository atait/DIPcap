  )
  (gr_text "1. Move top switch to series position\n2. Using multimeter, meas. R1\n3. Calculate target tau = RC\n4. Apply step signal, view in Oscope\n5. Adjust DIP switches until target tau\n6. Return top switch to disconnected" (at 2.54 13.97 180) (layer "B.SilkS") (tstamp 5d734ba2-58a8-41e1-a979-80c8e6587bf4)
    (effects (font (size 1 1) (thickness 0.15)) (justify left bottom mirror))
  )
  (gr_text "1. Find largest value less than target\n2. Turn on corresponding DIP switch\n3. Calculate difference remaining\n4. Repeat using the remainder" (at 2.54 27.94 180) (layer "B.SilkS") (tstamp 8f077bf8-f78d-4061-8e36-08e6cca373a5)
    (effects (font (size 1 1) (thickness 0.15)) (justify left bottom mirror))
  )
